# App (copy to .env and adjust)
AUTH_DISABLED=0
AUTH_ALLOWED_EMAIL_DOMAINS=
ENCRYPTION_SECRET=dev-encryption-secret-change-in-production
SESSION_SECRET=dev-session-secret-for-local-docker-development-only-must-be-at-least-sixty-four-bytes

# Bundled Zitadel (local): leave CLIENT_ID/SECRET empty, start with:
#   docker compose --profile local-idp up -d
# Auto-writes docker/zitadel/oidc.env on first boot.
#
# External IdP (production): set all OIDC_* below, start WITHOUT local-idp profile.
# Do not keep a stale docker/zitadel/oidc.env — entrypoint skips bootstrap when
# OIDC_CLIENT_ID and OIDC_CLIENT_SECRET are already set.
# OIDC_ISSUER=https://auth.example.com
# OIDC_ISSUER_INTERNAL=https://auth.example.com
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URI=https://isoo.example.com/auth/callback

# Memcached (optional — leave MEMCACHE_SERVER empty to disable caching)
# MEMCACHE_SERVER=memcached:11211
# MEMCACHE_NAMESPACE=isoo

# Storage backend (exactly one): local | git | webdav | s3
# local = data only under DATA_PATH; git/webdav/s3 use DATA_PATH as working cache
STORAGE_BACKEND=local

# Project data root (source of truth when STORAGE_BACKEND=local; cache otherwise)
# DATA_PATH=tmp/data

# Git (when STORAGE_BACKEND=git)
# GIT_REMOTE_URL=git@github.com:acme/isoo-data.git
# GIT_FORCE_PUSH=1
# GIT_AUTHOR_NAME=ISOO
# GIT_AUTHOR_EMAIL=isoo@local

# WebDAV (when STORAGE_BACKEND=webdav)
# WEBDAV_URL=https://dav.example.com/isoo-data
# WEBDAV_USERNAME=
# WEBDAV_PASSWORD=

# S3 / MinIO (when STORAGE_BACKEND=s3)
# S3_BUCKET=
# S3_PREFIX=isoo-data
# S3_REGION=us-east-1
# S3_ENDPOINT=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_FORCE_PATH_STYLE=0

# Template bundles directory (default: data/templates — tracked in this repo)
# TEMPLATES_PATH=data/templates

# Template bundle for new projects and rake template tasks (default: voca)
# TEMPLATE_ID=voca

# DeepL machine translation for French export (optional — leave empty to disable)
# DEEPL_API_KEY=

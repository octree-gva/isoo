# App (copy to .env and adjust)
AUTH_DISABLED=0
AUTH_ALLOWED_EMAIL_DOMAINS=
ENCRYPTION_SECRET=dev-encryption-secret-change-in-production
SESSION_SECRET=dev-session-secret-for-local-docker-development-only-must-be-at-least-sixty-four-bytes

# OIDC is auto-configured into docker/zitadel/oidc.env on first boot.
# Override here only if using an external IdP:
# OIDC_ISSUER=http://localhost:8080
# OIDC_ISSUER_INTERNAL=http://zitadel:8080
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URI=http://localhost:9292/auth/callback

# Memcached (optional — leave MEMCACHE_SERVER empty to disable caching)
# MEMCACHE_SERVER=memcached:11211
# MEMCACHE_NAMESPACE=isoo

# Git remote sync (optional — local commits always; push only when both are set)
# GIT_REMOTE_URL=git@github.com:acme/isoo-data.git
# GIT_FORCE_PUSH=1
# GIT_AUTHOR_NAME=ISOO
# GIT_AUTHOR_EMAIL=isoo@local

# Project data root (default: tmp/data — gitignored; nested git created by bin/init-data-git)
# DATA_PATH=tmp/data

# Template bundles directory (default: data/templates — tracked in this repo)
# TEMPLATES_PATH=data/templates

# Template bundle for new projects and rake template tasks (default: voca)
# TEMPLATE_ID=voca

<h1 id="projects-heading"><%= t('projects.title') %></h1>

<% if @projects.any? %>
  <ul id="projects-list" class="mt-8 space-y-4" aria-labelledby="projects-heading">
    <% @projects.each do |p| %>
      <li class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-3 border-b py-4">
        <span id="project-name-<%= p[:slug] %>" class="text-lg sm:text-xl break-words"><%= p[:name] %></span>
        <a class="btn btn-outline btn-sm w-full sm:w-auto shrink-0"
           href="/projects/<%= p[:slug] %>"
           aria-label="<%= t('actions.open_named', name: p[:name]) %>">
          <i class="ri-folder-open-line" aria-hidden="true"></i>
          <%= t('projects.open') %>
        </a>
      </li>
    <% end %>
  </ul>
<% else %>
  <p id="projects-empty" class="mt-8 text-lg opacity-80"><%= t('projects.empty') %></p>
<% end %>

<footer class="page-footer fixed bottom-0 inset-x-0 z-40 border-t border-neutral-200 bg-white/95 backdrop-blur-sm px-4 py-3"
        role="toolbar" aria-label="<%= t('a11y.page_actions') %>">
  <div class="mx-auto flex flex-wrap gap-3 justify-end max-w-3xl">
    <button type="button" class="btn btn-primary w-full sm:w-auto" data-wizard-open="new_project_modal"
            aria-haspopup="dialog" aria-controls="new_project_modal">
      <i class="ri-add-line" aria-hidden="true"></i>
      <%= t('projects.new.button') %>
    </button>
  </div>
</footer>

<dialog id="new_project_modal" class="modal" aria-labelledby="new_project_modal_title">
  <div class="modal-box bg-white">
    <form id="new-project-form" method="post" action="/projects">
      <h2 id="new_project_modal_title" class="font-bold text-2xl"><%= t('projects.new.title') %></h2>
      <p class="mt-2 text-lg opacity-80"><%= t('projects.new.template_hint', name: @project_template[:name], id: @project_template[:id]) %></p>
      <div class="mt-6 space-y-4">
        <label class="form-control w-full" for="project-name">
          <span class="label-text text-lg mb-2"><%= t('projects.new.name_label') %></span>
          <input class="input input-bordered w-full" id="project-name" name="name" autocomplete="organization"
                 placeholder="<%= t('projects.new.name_placeholder') %>" required>
        </label>
        <label class="form-control w-full" for="project-slug">
          <span class="label-text text-lg mb-2"><%= t('projects.new.slug_label') %></span>
          <input class="input input-bordered w-full" id="project-slug" name="slug" autocomplete="off"
                 placeholder="<%= t('projects.new.slug_placeholder') %>" required
                 aria-describedby="project-slug-hint">
          <span id="project-slug-hint" class="text-base opacity-70 mt-1"><%= t('projects.new.slug_hint') %></span>
        </label>
      </div>
      <div class="modal-action flex-col-reverse sm:flex-row-reverse gap-2 mt-6">
        <button class="btn btn-primary w-full sm:w-auto" type="submit">
          <i class="ri-add-line" aria-hidden="true"></i>
          <%= t('projects.new.submit') %>
        </button>
        <button type="button" class="btn btn-ghost w-full sm:w-auto" onclick="new_project_modal.close()">
          <%= t('actions.cancel') %>
        </button>
      </div>
    </form>
  </div>
  <form method="dialog" class="modal-backdrop" aria-label="<%= t('actions.cancel') %>">
    <button type="submit"><%= t('actions.cancel') %></button>
  </form>
</dialog>

<%= render('shared/_back_nav', locals: { href: "/projects/#{@slug}", label: t('a11y.back_to_project', name: @manifest.name) }) %>

<h1 id="annexes-heading"><%= t('annexes.folder_label') %></h1>
<p id="annexes-hint" class="opacity-80 mt-2 text-lg"><%= t('annexes.hint') %></p>

<form class="mt-6" method="post" action="/projects/<%= @slug %>/annexes" aria-describedby="annexes-hint">
  <button class="btn btn-primary btn-sm w-full sm:w-auto" type="submit">
    <i class="ri-add-line" aria-hidden="true"></i>
    <%= t('annexes.new') %>
  </button>
</form>

<section class="mt-8" aria-labelledby="annexes-slots-heading">
  <h2 id="annexes-slots-heading" class="text-2xl"><%= t('annexes.slots_heading') %></h2>
  <ul id="annexes-slots" class="mt-4 divide-y">
    <% if @annexes.empty? %>
      <li class="opacity-80 py-4 text-lg" role="status"><%= t('annexes.empty') %></li>
    <% end %>
    <% @annexes.each do |doc| %>
      <% doc_title = doc['title'] || doc['doc_id'] %>
      <% doc_path = "/projects/#{@slug}/docs/#{doc['doc_id']}" %>
      <% asset_kind = doc['asset_kind'] %>
      <% excluded = AnnexStatus.excluded?(doc) %>
      <li>
        <a class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-3 py-4 hover:bg-base-200 -mx-2 px-2 rounded-lg<%= excluded ? ' opacity-60' : '' %>"
           href="<%= doc_path %>"
           aria-label="<%= t('actions.open_named', name: doc_title) %>">
          <span class="flex flex-wrap items-center gap-2 min-w-0">
            <span id="annex-label-<%= doc['doc_id'] %>" class="text-lg sm:text-xl break-words"><%= doc_title %></span>
            <span class="badge badge-outline badge-md"><%= t("annex.asset_kind.#{asset_kind}") %></span>
            <% if excluded %>
              <span class="badge badge-warning badge-md"><%= t('annex.excluded_badge') %></span>
            <% end %>
          </span>
          <span class="btn btn-ghost btn-sm w-full sm:w-auto shrink-0 pointer-events-none">
            <i class="ri-arrow-right-line" aria-hidden="true"></i>
            <%= t('actions.open') %>
          </span>
        </a>
      </li>
    <% end %>
  </ul>
</section>
